.DS_Store
**/.DS_Store
.DS_Store?
*.env
.vscode
.vscode/*
build/
core/build/
user_payload/
# Generated by make user (cpio test ELFs + manifest)
rootfs/tests/*
!rootfs/tests/.gitkeep
# Optional local busybox (make user / build_busybox.sh)
rootfs/bin/*
!rootfs/bin/.gitkeep
third_party/busybox/
third_party/busybox-*/
# Busybox out-of-tree cache (survives make clean / config); see build_busybox.sh
.cache/
build/busybox-*/
*.log
__pycache__/
.claude/
.cursor/